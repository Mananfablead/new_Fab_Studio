import { useState } from 'react';
import { Sparkles, Check, Package, Database, Brain, Globe, Eye, Zap } from 'lucide-react';
import { Dialog, DialogContent, DialogHeader, DialogTitle, DialogDescription } from '@/components/ui/dialog';
import { Button } from '@/components/ui/button';

interface Feature {
  id: string;
  name: string;
  price: string;
  description: string;
  icon: string;
  color: string;
}

interface AddFeaturesModalProps {
  open: boolean;
  onOpenChange: (open: boolean) => void;
}

const addOnFeatures: Feature[] = [
  { 
    id: 'storage-10', 
    name: 'Extra Storage 10GB', 
    price: '₹199', 
    description: 'Add 10GB more storage to your plan',
    icon: 'database',
    color: 'from-blue-500 to-cyan-500',
  },
  { 
    id: 'storage-50', 
    name: 'Extra Storage 50GB', 
    price: '₹799', 
    description: 'Add 50GB more storage to your plan',
    icon: 'database',
    color: 'from-indigo-500 to-purple-500',
  },
  { 
    id: 'ai-credits', 
    name: 'AI Recognition Credits', 
    price: '₹499', 
    description: 'Additional 10,000 AI face recognitions',
    icon: 'brain',
    color: 'from-pink-500 to-rose-500',
  },
  { 
    id: 'custom-domain', 
    name: 'Custom Domain', 
    price: '₹299', 
    description: 'Use your own domain for galleries',
    icon: 'globe',
    color: 'from-green-500 to-emerald-500',
  },
  { 
    id: 'remove-branding', 
    name: 'Remove Branding', 
    price: '₹199', 
    description: 'Remove fab-photo branding from galleries',
    icon: 'eye',
    color: 'from-amber-500 to-orange-500',
  },
  { 
    id: 'priority-delivery', 
    name: 'Priority Delivery', 
    price: '₹399', 
    description: 'Faster photo delivery with CDN boost',
    icon: 'zap',
    color: 'from-violet-500 to-purple-500',
  },
];

const IconComponent = ({ icon, className }: { icon: string; className?: string }) => {
  switch (icon) {
    case 'database':
      return <Database className={className} />;
    case 'brain':
      return <Brain className={className} />;
    case 'globe':
      return <Globe className={className} />;
    case 'eye':
      return <Eye className={className} />;
    case 'zap':
      return <Zap className={className} />;
    default:
      return <Package className={className} />;
  }
};

export default function AddFeaturesModal({ open, onOpenChange }: AddFeaturesModalProps) {
  const [selectedFeature, setSelectedFeature] = useState<string | null>(null);

  const handleAddFeature = () => {
    if (selectedFeature) {
      console.log('Adding feature:', selectedFeature);
      onOpenChange(false);
      setSelectedFeature(null);
    }
  };

  return (
    <Dialog open={open} onOpenChange={onOpenChange}>
      <DialogContent className="max-w-lg max-h-[90vh] overflow-y-auto p-0 gap-0 border-0 bg-transparent shadow-none scrollbar-hide [&>button]:text-white [&>button]:hover:text-[hsl(var(--fab-amber))] [&>button]:bg-white/10 [&>button]:hover:bg-white/20 [&>button]:rounded-full [&>button]:p-2 [&>button]:transition-colors [&::-webkit-scrollbar]:hidden [-ms-overflow-style:none] [scrollbar-width:none]">
        {/* Glass Card */}
        <div className="bg-white/95 backdrop-blur-xl rounded-xl border border-white/20 shadow-2xl overflow-hidden">
          {/* Header */}
          <div className="relative px-8 pt-8 pb-6 bg-gradient-to-br from-[hsl(var(--fab-navy))] to-[hsl(var(--fab-navy))]/90">
            <div className="absolute top-0 right-0 w-48 h-48 bg-[hsl(var(--fab-amber))]/10 rounded-full blur-3xl -translate-y-1/2 translate-x-1/2" />
            <DialogHeader className="relative">
              <div className="flex items-center gap-3 mb-3">
                <div className="w-12 h-12 rounded-xl bg-gradient-to-br from-[hsl(var(--fab-amber))] to-orange-500 flex items-center justify-center shadow-lg">
                  <Sparkles className="w-6 h-6 text-white" />
                </div>
                <div>
                  <DialogTitle className="text-xl font-heading font-bold text-white">
                    Add Features
                  </DialogTitle>
                  <DialogDescription className="text-white/70 text-sm">
                    Enhance your subscription
                  </DialogDescription>
                </div>
              </div>
            </DialogHeader>
          </div>

          {/* Features List */}
          <div className="p-6 space-y-3">
            {addOnFeatures.map((feature) => (
              <button
                key={feature.id}
                onClick={() => setSelectedFeature(feature.id)}
                className={`w-full p-4 rounded-xl border-2 text-left transition-all duration-300 group ${
                  selectedFeature === feature.id
                    ? 'border-[hsl(var(--fab-amber))] bg-[hsl(var(--fab-amber))]/5 shadow-lg'
                    : 'border-border hover:border-[hsl(var(--fab-amber))]/30 hover:bg-muted/30'
                }`}
              >
                <div className="flex items-center gap-4">
                  {/* Icon */}
                  <div className={`w-12 h-12 rounded-xl bg-gradient-to-br ${feature.color} flex items-center justify-center shadow-md shrink-0`}>
                    <IconComponent icon={feature.icon} className="w-5 h-5 text-white" />
                  </div>

                  {/* Info */}
                  <div className="flex-1 min-w-0">
                    <div className="flex items-center justify-between gap-2">
                      <p className="font-semibold text-sm truncate">{feature.name}</p>
                      <span className="text-sm font-bold text-[hsl(var(--fab-amber))] shrink-0">{feature.price}</span>
                    </div>
                    <p className="text-xs text-muted-foreground mt-0.5">{feature.description}</p>
                  </div>

                  {/* Check */}
                  <div className={`w-6 h-6 rounded-full border-2 flex items-center justify-center shrink-0 transition-all ${
                    selectedFeature === feature.id
                      ? 'border-[hsl(var(--fab-amber))] bg-[hsl(var(--fab-amber))]'
                      : 'border-muted-foreground/30'
                  }`}>
                    {selectedFeature === feature.id && <Check className="w-3.5 h-3.5 text-white" />}
                  </div>
                </div>
              </button>
            ))}
          </div>

          {/* Footer Buttons */}
          <div className="px-6 pb-6">
            <div className="flex gap-3">
              <Button 
                variant="outline" 
                className="flex-1 py-5 rounded-xl font-medium border-2"
                onClick={() => onOpenChange(false)}
              >
                Cancel
              </Button>
              <Button 
                className="flex-1 py-5 rounded-xl font-semibold bg-gradient-to-r from-[hsl(var(--fab-amber))] to-orange-500 text-white hover:shadow-lg hover:shadow-orange-500/25 disabled:opacity-50"
                disabled={!selectedFeature}
                onClick={handleAddFeature}
              >
                Add Feature
              </Button>
            </div>
          </div>
        </div>
      </DialogContent>
    </Dialog>
  );
}
